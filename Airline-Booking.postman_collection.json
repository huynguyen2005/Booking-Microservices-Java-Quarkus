        {
          "name": "Login User (save userToken, userId)",
          "event": [{
            "listen": "test",
            "script": {
              "type": "text/javascript",
              "exec": [
                "const json = pm.response.json();",
                "if (json.token) pm.environment.set('userToken', json.token);",
                "if (json.user && json.user.id) pm.environment.set('userId', json.user.id);"
              ]
            }
          }],
          "request": {
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"email\": \"user1@gmail.com\",\n  \"password\": \"123456\"\n}"
            },
            "url": "{{baseUrl}}/api/auth/login",
            "description": "Login USER and store user token/id in environment."
          }
        },
        {
          "name": "Login Admin (save adminToken)",
          "event": [{
            "listen": "test",
            "script": {
              "type": "text/javascript",
              "exec": [
                "const json = pm.response.json();",
